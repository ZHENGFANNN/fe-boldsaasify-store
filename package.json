{
  "name": "fe-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": " yarn fetch-dev && next dev -p 8080",
    "prod": "yarn fetch && next prod -p 8080",
    "fetch-dev": "node ./script http://127.0.0.1:3080 https://www.sslfly.com",
    "fetch": "node ./script https://service.sslfly.com https://www.sslfly.com",
    "start": "next start -p 8080",
    "analyze": "yarn fetch && ANALYZE=true next build",
    "build": "yarn fetch && next build"
  },
  "dependencies": {
    "@paypal/react-paypal-js": "^8.1.3",
    "@splidejs/splide": "^4.1.4",
    "accept-language-parser": "^1.5.0",
    "axios": "^1.6.1",
    "chalk": "4.1.2",
    "js-cookie": "^3.0.5",
    "moment": "^2.29.4",
    "next": "14.0.2",
    "next-i18n-router": "^5.0.1",
    "next-plugin-antd-less": "^1.8.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.48.2",
    "react-html-parser": "^2.0.2",
    "sitemap": "^7.1.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.2"
  }
}
