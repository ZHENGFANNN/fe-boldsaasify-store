{
  "name": "fe-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "fetch-dev": "NODE_ENV=local node ./script",
    "fetch-prod": "node ./script",
    "dev": "yarn fetch-prod && next dev -p 8080",
    "prod": "yarn fetch-prod && next prod -p 8080",
    "start": "next start -p 8080",
    "analyze": "yarn fetch-prod && ANALYZE=true next build",
    "build": "next build --webpack",
    "cf-build": "opennextjs-cloudflare build",
    "cf-preview": "opennextjs-cloudflare preview",
    "cf-deploy": "opennextjs-cloudflare deploy -- --keep-vars",
    "preview": "yarn fetch-prod && yarn cf-build && yarn cf-preview",
    "deploy": "yarn fetch-prod && yarn cf-build && yarn cf-deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@paypal/react-paypal-js": "^8.1.3",
    "@react-oauth/google": "^0.13.5",
    "@splidejs/splide": "^4.1.4",
    "@stripe/react-stripe-js": "^3.7.0",
    "@stripe/stripe-js": "^5.6.0",
    "@upstash/redis": "^1.34.0",
    "accept-language-parser": "^1.5.0",
    "add": "^2.0.6",
    "axios": "^1.6.1",
    "body-scroll-lock": "^4.0.0-beta.0",
    "chalk": "4.1.2",
    "compressorjs": "^1.2.1",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "gsap": "^3.12.2",
    "ioredis": "^5.4.1",
    "jotai": "^2.10.0",
    "jquery": "^3.7.1",
    "js-cookie": "^3.0.5",
    "maxmind": "^4.3.22",
    "moment": "^2.29.4",
    "msgpack-lite": "^0.1.26",
    "next": "16.2.7",
    "next-i18n-router": "^5.0.1",
    "qs": "^6.12.3",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.48.2",
    "react-html-parser": "^2.0.2",
    "sass": "^1.69.5",
    "server-only": "^0.0.1",
    "typescript": "5.9.3",
    "vconsole": "^3.15.1",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.0.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.7",
    "wrangler": "^4.49.1"
  }
}
