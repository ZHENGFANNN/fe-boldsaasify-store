{
  "name": "fe-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "fetch-dev": "NODE_ENV=local node ./script",
    "fetch-prod": "NODE_ENV=prod node ./script",
    "dev": " yarn fetch-dev && next dev -p 8080",
    "prod": "yarn fetch-prod && next prod -p 8080",
    "start": "next start -p 8080",
    "analyze": "yarn fetch-prod && ANALYZE=true next build",
    "build": "yarn fetch-prod && next build"
  },
  "dependencies": {
    "@paypal/react-paypal-js": "^8.1.3",
    "@splidejs/splide": "^4.1.4",
    "@upstash/redis": "^1.34.0",
    "accept-language-parser": "^1.5.0",
    "add": "^2.0.6",
    "axios": "^1.6.1",
    "body-scroll-lock": "^4.0.0-beta.0",
    "chalk": "4.1.2",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "gsap": "^3.12.2",
    "ioredis": "^5.4.1",
    "jquery": "^3.7.1",
    "js-cookie": "^3.0.5",
    "moment": "^2.29.4",
    "msgpack-lite": "^0.1.26",
    "next": "14.1.0",
    "next-i18n-router": "^5.0.1",
    "qs": "^6.12.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.48.2",
    "react-html-parser": "^2.0.2",
    "sass": "^1.69.5",
    "server-only": "^0.0.1",
    "sitemap": "^7.1.1",
    "vconsole": "^3.15.1",
    "wrangler": "^3.67.1",
    "yarn": "^1.22.21",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.2"
  }
