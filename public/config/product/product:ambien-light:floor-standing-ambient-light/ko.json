ode":null},{"type":"image","title":null,"description":null,"video_src":null,"poster_src":null,"image_src":"https://files.sslfly.com/image/base/2024/1/19/523C7C075AB3E25DEBF148350A55ABCF/%E6%B8%90%E5%8F%98%E9%95%BF%E6%AC%BE%E6%B0%9B%E5%9B%B4%E7%81%AF_11.jpg?width=790&height=790","media_code":null},{"type":"image","title":null,"description":null,"video_src":null,"poster_src":null,"image_src":"https://files.sslfly.com/image/base/2024/1/19/0F567094EEF047C65DDEC74255FD2698/%E6%B8%90%E5%8F%98%E9%95%BF%E6%AC%BE%E6%B0%9B%E5%9B%B4%E7%81%AF_12.jpg?width=790&height=790","media_code":null}],"associationsList":[{"value":"5V/500MA-1A","key":"VOLTAGE"},{"value":"5W","key":"POWER"},{"value":"USB","key":"POWER SUPPLY MODE"},{"value":"50PCS/60PCS","key":"LED QTY"},{"value":"RGB+WARMLIGHT+WHITE LIGHT","key":"COLOR/TEMPERTUNE"},{"value":"PC","key":"MATERIAL"}],"faqList":[],"sellingList":[{"light":"Customize color, beat speed and brightness"},{"light":"Stepless dimming"},{"light":"Three control methods"}],"reviewsList":[{"name":"chris","score":5,"weight":6,"comment":"I have it in my music room and it's fantastic, it matches perfectly and the ambiance is spot on","image":null,"video":"https://files.sslfly.com/video/base/2024/2/1/5F022A1C511445B422EE23A6F42A391D/435435.mp4?width=1280&height=720","type":"video"},{"name":"\tPork","score":5,"weight":5,"comment":"Picked up this light to add to my apartment and it’s amazing. Easy to use and setup and very customizable. Lights can be bright and the remote was very responsive. Pretty amazing product for the price.","image":"https://files.sslfly.com/image/base/2024/2/1/5ACA4094C9F86C95FBAA5A024760EFD0/%E5%BE%AE%E4%BF%A1%E6%88%AA%E5%9B%BE_20240201112121.png?width=444&height=592","video":null,"type":"image"},{"name":"Click Junkie","score":5,"weight":5,"comment":"This is sort of a zen addition to any room. I’ve found that the app works the best for scheduling an “on and off” time and playing with the multitude of color combinations and settings available with this lamp.\n\nYou face the light bar towards any blank wall and turn it on. It’s that easy. Then enjoy a soothing sort of aura of color in your room. It’s not overly bright or garish, and is especially nice when you’re just watching tv with all the lights low.\n\nOriginally got this for my granddaughter, but decided to keep it.","image":"https://files.sslfly.com/image/base/2024/2/1/41363E96F032FA5C36DFA963860FB312/%E5%BE%AE%E4%BF%A1%E6%88%AA%E5%9B%BE_20240201112426.png?width=446&height=593","video":null,"type":"image"},{"name":"winwin","score":5,"weight":5,"comment":"HOLY WOW, THESE LIGHTS ARE FIRE! If you don't have these yet, you better hit that button & purchase and you'll have the most talked about room in an EPIC way.. These are easy to assemble, 360° turning radius, Bluetooth enabled & too many light combos to count! These LED lights are way more in value then the cost... YOU'LL REGRET IT IF YOU DON'T BUY THEM","image":null,"video":"https://files.sslfly.com/video/base/2024/2/1/47CA00DD849FDD805BCF2A6CE24AB205/fangge.mp4?width=720&height=1280","type":"video"},{"name":"Jaime Johnston","score":5,"weight":4,"comment":"We bought one of these lights for our son to set up in his gaming area. We liked it so much we got two more for our TV area. We even used them on the music mode for a karaoke party we hosted, which added a great party atmosphere.","image":"https://files.sslfly.com/image/base/2024/2/1/08F23996343B7C4064492185CC86DBCE/%E5%BE%AE%E4%BF%A1%E6%88%AA%E5%9B%BE_20240201112344.png?width=275&height=598","video":null,"type":"image"},{"name":"A Bhat","score":5,"weight":4,"comment":"This product is great with vibrant colors . Enhances the vibrance of any room.","image":"https://files.sslfly.com/image/base/2024/2/1/1529E10CE8E5496D57DFE94DE2C590EB/%E5%BE%AE%E4%BF%A1%E6%88%AA%E5%9B%BE_20240201112437.png?width=449&height=590","video":null,"type":"image"},{"name":"Ksten","score":5,"weight":4,"comment":"Cool lamp for my son’s room. It works well. The assembly was pretty easy. I glanced at the directions and was able to complete it in about 5 minutes. the stand has been decent even on carpet.","image":"https://files.sslfly.com/image/base/2024/2/1/E0149FC15E3CFDE5C29FCFB1C3666EB0/%E5%BE%AE%E4%BF%A1%E6%88%AA%E5%9B%BE_20240201114134.png?width=403&height=403","video":null,"type":"image"},{"name":"Raymond C","score":5,"weight":1,"comment":"The light is beautiful and easy to operate. And I like various color effects that can change! It is so nice at a reasonable price","image":null,"video":null,"type":"text"},{"name":"Sherry","score":5,"weight":1,"comment":"Both if my kids wanted a night light for their bedroom. After searching numerous different options this is the one we decided to purchase for both of them. It came very quickly and was packaged very nice. It was so easy to put together. Maybe like 3 or 4 steps for the whole process of setting it up and took maybe 2 minutes to put together. They both came with their own remotes. The kids have loved being able to change the colors on the lights. There are so many different settings you can change the lights to. Would reccomend this light for kids or adults. We would definetly purchase this item again.","image":null,"video":null,"type":"text"},{"name":"Sylvia J Madden","score":5,"weight":1,"comment":"Easy to put together and puts off really nice light. Easy to change colors between solid lights. Some of the modes might drive ya crazy with the flickering, lol, but the mode that starts the light from the bottom up is awesome.","image":null,"video":null,"type":"text"}],"comboList":[{"id":183,"key":"bluetooth-remote-control-floor-standing-ambient-light-10w-2","title":"Bluetooth remote control floor-standing ambient light (10w) - 2pcs","description":null,"img_list":[],"smart_img":null,"areaList":[{"country_code":"gb","currency":"GBP","currency_symbol":"£","currency_unit":null,"product_price":36.59,"selling_price":25.61,"product_discount":70,"stock":true},{"country_code":"ch","curr